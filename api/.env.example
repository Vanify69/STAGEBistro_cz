DATABASE_URL=postgresql://postgres:postgres@localhost:5433/stagebistro
PORT=3001
NODE_ENV=development
SESSION_SECRET=change-me-in-production
# Lokál: Vite. Railway (jen služba API): přesná URL webu z Networking u Web, např. https://web-production-f0830.up.railway.app
# Stejný účel (libovolná z nich): CORS_ORIGIN | CORS_ORIGINS | ALLOWED_ORIGINS | FRONTEND_ORIGIN | WEB_ORIGIN
# Jen hostname (API doplní https://): WEB_PUBLIC_DOMAIN=web-production-f0830.up.railway.app
# Reference: https://${{Web.RAILWAY_PUBLIC_DOMAIN}} (Web = přesný název služby na canvasu)
CORS_ORIGIN=http://localhost:5173

# Run SQL migrations from ./drizzle on startup (Railway: set to true for first deploy)
MIGRATE_ON_START=false

# First admin user (used by `npm run api:seed` when user does not exist)
ADMIN_EMAIL=admin@stagebistro.local
ADMIN_PASSWORD=changeme

# Cloudflare R2 (S3-compatible) for receipt uploads — optional; without these, presign returns 503
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
