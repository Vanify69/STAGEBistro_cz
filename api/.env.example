DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/stagebistro
PORT=3001
NODE_ENV=development
SESSION_SECRET=change-me-in-production
# Lokál: Vite. Railway (jen služba API): přesná URL webu z Networking u Web, např. https://web-production-f0830.up.railway.app
# Stejný účel (libovolná z nich): CORS_ORIGIN | CORS_ORIGINS | ALLOWED_ORIGINS | FRONTEND_ORIGIN | WEB_ORIGIN
# Jen hostname (API doplní https://): WEB_PUBLIC_DOMAIN=web-production-f0830.up.railway.app
# Reference: https://${{Web.RAILWAY_PUBLIC_DOMAIN}} (Web = přesný název služby na canvasu)
CORS_ORIGIN=http://localhost:5173

# Run SQL migrations from ./drizzle on startup (Railway API: true) — nemění obsah tabulek
MIGRATE_ON_START=true
# Seed (admin, výchozí nastavení) jen jednorázově — nikdy true na produkci po prvním deployi
SEED_ON_START=false

# First admin user (used by `npm run api:seed` when user does not exist)
ADMIN_EMAIL=admin@stagebistro.local
ADMIN_PASSWORD=changeme

# Provozní přihlášení (seed vytvoří uživatele, pokud neexistuje)
PROVOZ_EMAIL=
PROVOZ_PASSWORD=
# PROVOZ_RESET_PASSWORD=true — při seedu přenastaví heslo existujícímu provoznímu účtu

# Veřejná URL webu (odkazy v e-mailech) — na Railway obvykle https://www.stagebistro.cz
APP_PUBLIC_URL=http://localhost:5173

# Notifikace účetní — nové smlouvy DPC (jen když je smlouva aktivní a má soubor)
UCETNI_EMAIL=
# SMTP (Gmail, Seznam, vlastní server…)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Stage Bistro <noreply@stagebistro.cz>

# Cloudflare R2 (S3-compatible) for receipt uploads — optional; without these, presign returns 503
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Veřejná báze URL bucketu (bez koncového /), např. https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=
